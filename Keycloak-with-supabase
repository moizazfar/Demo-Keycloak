# PHASE 5 — AIOps Service Integration

## Step 14: Python Example — AIOps Service Using Keycloak + Supabase

```python
# aiops_service/supabase_client.py
# How your AIOps ML services query Supabase with Keycloak auth

import httpx
import os

KEYCLOAK_URL = os.getenv("KEYCLOAK_URL")
SUPABASE_URL = os.getenv("SUPABASE_URL")
SUPABASE_ANON_KEY = os.getenv("SUPABASE_ANON_KEY")

async def get_keycloak_token(username: str, password: str) -> str:
    """Get JWT token from Keycloak"""
    async with httpx.AsyncClient(verify=False) as client:
        response = await client.post(
            f"{KEYCLOAK_URL}/realms/aiops-dev"
            f"/protocol/openid-connect/token",
            data={
                "username": username,
                "password": password,
                "grant_type": "password",
                "client_id": "supabase",
                "client_secret": os.getenv("KC_CLIENT_SECRET"),
            }
        )
        return response.json()["access_token"]

async def query_aiops_data(token: str, table: str) -> dict:
    """Query Supabase using Keycloak token"""
    async with httpx.AsyncClient(verify=False) as client:
        response = await client.get(
            f"{SUPABASE_URL}/rest/v1/{table}",
            headers={
                # Keycloak JWT token here
                "Authorization": f"Bearer {token}",
                # Supabase anon key
                "apikey": SUPABASE_ANON_KEY,
                "Content-Type": "application/json",
            }
        )
        return response.json()

# Usage in your AIOps pipeline:
async def main():
    # 1. Get token from Keycloak
    token = await get_keycloak_token("ml-service-user", "password")

    # 2. Query AIOps data from Supabase
    anomalies = await query_aiops_data(token, "aiops_events")
    logs = await query_aiops_data(token, "log_analysis")
    metrics = await query_aiops_data(token, "system_metrics")

    print(f"Got {len(anomalies)} anomaly records")
    return anomalies
```

